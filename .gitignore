# Root safety net. The Next.js app/ folder has its own .gitignore that covers
# node_modules, .next, build output, and env files for that subtree.

# OS
.DS_Store

# Editors
.vscode/
.idea/

# Dependencies / build (any level)
node_modules/
.next/
out/
build/
coverage/

# Secrets — never commit. Use *.example templates instead.
.env
.env.*
!.env.example

# Logs
*.log
.vercel
